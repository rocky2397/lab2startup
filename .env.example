# Lab2Startup local environment (not committed — see .gitignore)
# Copy to .env and fill in your keys.

# Production mode: dashboard loads SQLite runs; mock JSON is for tests/dev only
LAB2STARTUP_MODE=production
LAB2STARTUP_PAPER_SOURCE=openreview
LAB2STARTUP_USE_MOCK_SIGNALS=false

# Perplexity founder search — primary signal source (enabled when API key is set)
LAB2STARTUP_PERPLEXITY_ENABLED=true
LAB2STARTUP_PERPLEXITY_API_KEY=
LAB2STARTUP_PERPLEXITY_MODEL=sonar-pro
LAB2STARTUP_PERPLEXITY_MAX_RESEARCHERS=15
LAB2STARTUP_PERPLEXITY_MAX_SIGNALS_PER_RESEARCHER=2
LAB2STARTUP_PERPLEXITY_MIN_IDENTITY=high
LAB2STARTUP_PERPLEXITY_SUPPLEMENT_MOCK=false
LAB2STARTUP_PERPLEXITY_REQUEST_DELAY=1.0
LAB2STARTUP_PERPLEXITY_MAX_WORKERS=3

# Optional OSS supplement (off by default — Perplexity is primary)
LAB2STARTUP_GITHUB_ENABLED=false

# OpenReview — papers only; affiliations resolved by Perplexity (no profile API calls)
LAB2STARTUP_OPENREVIEW_ENABLED=true
LAB2STARTUP_OPENREVIEW_CONFERENCE=NeurIPS
LAB2STARTUP_OPENREVIEW_YEAR=2024
LAB2STARTUP_OPENREVIEW_FETCH_PROFILES=false
LAB2STARTUP_OPENREVIEW_REQUEST_DELAY=1.0
LAB2STARTUP_OPENREVIEW_MAX_RETRIES=6

# Perplexity also resolves affiliation/role/identity (combined with founder signals)
LAB2STARTUP_PERPLEXITY_ENRICH_PROFILES=true

# Pipeline disk cache (development mode only — production uses SQLite runs)
LAB2STARTUP_PIPELINE_CACHE_ENABLED=true
LAB2STARTUP_PIPELINE_CACHE_TTL_HOURS=168

# Backtrace Capital fund scope (default)
LAB2STARTUP_FUND=backtrace
