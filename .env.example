# Lab2Startup local environment (not committed — see .gitignore)
# Copy to .env and fill in your keys.

# Perplexity founder search (enabled by default when API key is set)
LAB2STARTUP_PERPLEXITY_ENABLED=true
LAB2STARTUP_PERPLEXITY_API_KEY=
LAB2STARTUP_PERPLEXITY_MODEL=sonar-pro
LAB2STARTUP_PERPLEXITY_MAX_RESEARCHERS=10
LAB2STARTUP_PERPLEXITY_MAX_SIGNALS_PER_RESEARCHER=2
LAB2STARTUP_PERPLEXITY_MIN_IDENTITY=high
LAB2STARTUP_PERPLEXITY_SUPPLEMENT_MOCK=true
LAB2STARTUP_PERPLEXITY_REQUEST_DELAY=1.0
LAB2STARTUP_PERPLEXITY_MAX_WORKERS=3

# Pipeline disk cache (speeds up dashboard/API restarts)
LAB2STARTUP_PIPELINE_CACHE_ENABLED=true
LAB2STARTUP_PIPELINE_CACHE_TTL_HOURS=168

# Backtrace Capital fund scope (default)
LAB2STARTUP_FUND=backtrace
